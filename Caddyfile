{$DOMAIN} {
    # API + Auth an FastAPI weiterleiten
    handle /api/* {
        reverse_proxy {$API_UPSTREAM:localhost:8000}
    }

    handle /auth/* {
        reverse_proxy {$API_UPSTREAM:localhost:8000}
    }

    handle /health {
        reverse_proxy {$API_UPSTREAM:localhost:8000}
    }

    # Alles andere: React SPA aus dem dist-Verzeichnis
    handle {
        root * /srv/dashboard
        try_files {path} /index.html
        file_server
    }

    encode gzip

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    log {
        output file /data/logs/access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}

# Integration Betriebsleitfaden (separater Dienst, eigener Container)
bl.kiste.org {
    reverse_proxy 10.88.0.1:8001
    encode gzip
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
