# Produktions-Umgebungsvariablen
# Kopieren nach .env.prod und anpassen

# Domain (für Caddy / Let's Encrypt)
DOMAIN=netasset.example.com

# GitHub-Repo für Container-Image (user/repo)
GITHUB_REPO=myuser/netasset
IMAGE_TAG=latest

# Datenbank-Passwort – starkes Passwort wählen!
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Modell – beliebig wählbar (anthropic/claude-sonnet-4-5, openai/gpt-4o, ...)
LLM_MODEL=anthropic/claude-sonnet-4-5

# NVD API Key (optional, erhöht Rate-Limit)
NVD_API_KEY=

# Embedding-Modell
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Log-Level
LOG_LEVEL=INFO
